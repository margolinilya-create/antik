# Supabase — see https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for canonical links, sitemap, OG images)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# On-demand ISR revalidation secret (Supabase DB webhook -> /api/revalidate)
REVALIDATE_SECRET=

# Lead notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Analytics (optional — features are no-op when unset)
NEXT_PUBLIC_YANDEX_METRICA_ID=
NEXT_PUBLIC_GA_ID=
# Search Console / Webmaster verification (meta tags)
NEXT_PUBLIC_YANDEX_VERIFICATION=
NEXT_PUBLIC_GOOGLE_VERIFICATION=

# Error monitoring (optional)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Rate limiting for public forms (optional — Upstash Redis REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
